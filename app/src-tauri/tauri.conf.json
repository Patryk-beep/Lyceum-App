{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lyceum",
  "version": "0.1.3",
  "identifier": "app.lyceum.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "lyceum — learning/ — local workspace",
        "width": 1240,
        "height": 820,
        "minWidth": 940,
        "minHeight": 640,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Patryk-beep/Lyceum-App/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk4MUEwODUyMEIzNzhCOTYKUldTV2l6Y0xVZ2dhbUxoTVhOT2JTaE9adWhLVmxsTEEwdmkzNFZ6Slh2MDdhYlgxbG9Td2o4NHQK",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Education",
    "shortDescription": "Learn any subject to mastery, guided by Claude.",
    "resources": ["resources/lyceum/**/*"],
    "createUpdaterArtifacts": false,
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
